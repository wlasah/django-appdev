# Django Backend - Environment Variables Template
# Copy this file to .env and fill in your values for your environment

# ========== SECURITY ==========
# Set to False for production
DEBUG=True

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
# NEVER commit real keys to Git! Use environment variables on server.
SECRET_KEY=your-secret-key-here-generate-random-50-char-string

# ========== DATABASE ==========
# Development (SQLite): sqlite:///db.sqlite3
# Production (PostgreSQL): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# ========== DEPLOYMENT ==========
# Allowed hostnames (comma-separated)
# Development: localhost,127.0.0.1
# Production: yourapp.railway.app,yourapp.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ========== CORS - Frontend URLs (comma-separated) ==========
# Development: http://localhost:3000
# Production: https://yourfrontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ========== EMAIL (optional) ==========
# For error notifications and email alerts
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ========== AWS S3 (optional, for file uploads) ==========
# Uncomment if using S3 for media storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=

