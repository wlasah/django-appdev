# Production Environment Variables for Render.com
# Copy these into Render Dashboard when deploying

# ========== SECURITY ==========
DEBUG=False
SECRET_KEY=django-insecure-prod-change-this-to-random-string-during-lab

# ========== HOSTING ==========
# Update this after Render gives you the deployment URL
ALLOWED_HOSTS=smart-plant-backend.onrender.com,localhost,127.0.0.1

# ========== CORS - Update with your Vercel URL ==========
# Format: https://your-vercel-app-name.vercel.app
CORS_ALLOWED_ORIGINS=https://smart-plant-watering.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# ========== DATABASE ==========
# ⚠️ IMPORTANT: Use PostgreSQL for production (Render has ephemeral filesystem)
# SQLite data WILL BE LOST when Render restarts!

# For PostgreSQL (RECOMMENDED for production on Render):
# 1. Create PostgreSQL database on Render dashboard
# 2. Get the DATABASE_URL from Render
# 3. Paste it below (Render provides the full URL)
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_database

# For local development ONLY (SQLite):
# DATABASE_URL=sqlite:///db.sqlite3

# ========== EMAIL (optional) ==========
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ========== STATIC FILES ==========
STATIC_URL=/static/
STATIC_ROOT=staticfiles

# ========== MEDIA FILES (optional) ==========
MEDIA_URL=/media/
MEDIA_ROOT=media
